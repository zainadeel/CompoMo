{
  "name": "@compomo/ui",
  "version": "0.1.0",
  "description": "CompoMo — composable React UI components styled with TokoMo design tokens",
  "keywords": [
    "react",
    "components",
    "ui",
    "design-system",
    "component-library",
    "css-modules",
    "typescript"
  ],
  "homepage": "https://github.com/zainadeel/compomo#readme",
  "bugs": "https://github.com/zainadeel/compomo/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/zainadeel/compomo.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./css": "./dist/index.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "@tokomo/tokens": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@icomo/icons": {
      "optional": true
    }
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/react": "^8.6.0",
    "@storybook/react-vite": "^8.6.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^8.6.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "@tokomo/tokens": "file:../TokoMo",
    "@icomo/icons": "file:../IcoMo"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": [
    "**/*.css"
  ]
}
